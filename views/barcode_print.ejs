<!DOCTYPE html>
<html>
<head>
  <style>
    .page {
        display: grid;
        grid-template-columns: repeat(4, 1.5in);
        grid-auto-rows: 0.8in;
        gap: 0.3in;
        margin: 0.1in   ;
      }
       .barcode {
          width: 3.5cm;
            height: 0.8in;
            overflow: hidden;
            display: flex;
            align-items: center;
            border: 1px solid black;
            padding: 0.3mm 2mm;
            justify-content: center;
      }
      
      body {
        margin: 0;
      }



      .barcode img {
        width: 100%;
      }
    @media print {

      @page {
        size: A4;
        margin: 0.09in;
      }

    }
  </style>
</head>
<body>

<%
  const perPage = 40;
  for (let i = 0; i < products.length; i += perPage) {
%>

  <div class="page">
    <% products.slice(i, i + perPage).forEach(product => { %>
      <%for(let i=0;i<product.stock;i++){%>
          <div class="barcode">
              <img src="/admin/products/regenerate/<%= product.barcode%>">
          </div>
        <%}%>
    <% }) %>
  </div>

<% } %>
<script>
    window.onload = function () {
    window.print();

    // window.onafterprint = function () {
    //     window.location.href = `/admin/products/updatePrintCount?${window.location.search}`;
    // };
};
    </script>



</body>
</html>
